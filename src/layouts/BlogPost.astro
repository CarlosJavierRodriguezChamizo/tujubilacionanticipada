---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
// Guía oculta temporalmente: import CTAGuia from '../components/CTAGuia.astro';
import { formatDate, toISO } from '../lib/posts';
import { blogPostingSchema, breadcrumbSchema } from '../lib/schema';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import AsesoramientoCard from '../components/AsesoramientoCard.astro';
import { SITE } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;
const path = `/blog/${post.slug}`;
const shareUrl = new URL(path, SITE.url).toString();

const articleSchema = blogPostingSchema(post);
const breadcrumb = breadcrumbSchema([
  { name: 'Inicio', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: data.title, path },
]);
---

<Base
  title={data.title}
  description={data.description}
  path={path}
  image={data.ogImage ?? data.heroImage}
  ogType="article"
  schema={[articleSchema, breadcrumb]}
>
  <article class="container-prose py-10 sm:py-14">
    <nav aria-label="Migas de pan" class="mb-6 text-sm text-ink-muted">
      <a href="/" class="hover:text-brand-600">Inicio</a>
      <span class="px-1.5" aria-hidden="true">/</span>
      <a href="/blog" class="hover:text-brand-600">Blog</a>
    </nav>

    <header class="mx-auto max-w-prose">
      <p class="eyebrow">
        {data.category}
      </p>
      <h1 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">
        {data.title}
      </h1>
      <p class="mt-4 text-lg text-ink-soft">{data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-ink-muted">
        <span>{data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={toISO(data.pubDate)}>{formatDate(data.pubDate)}</time>
        {
          data.updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Actualizado: {formatDate(data.updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    {
      data.heroImage && (
        <figure class="mx-auto mt-8 max-w-3xl">
          <img
            src={data.heroImage}
            alt={data.heroImageAlt ?? data.title}
            width="1200"
            height="675"
            loading="eager"
            class="aspect-video w-full rounded-xl border border-paper-200 object-cover"
          />
        </figure>
      )
    }

    <ShareButtons url={shareUrl} title={data.title} />

    <hr class="mx-auto mt-8 max-w-prose border-paper-300" />

    <div class="prose prose-lg mx-auto mt-8 prose-a:font-medium">
      <slot />
    </div>

    {/* Guía oculta temporalmente hasta que el producto esté definido.
    <div class="mx-auto mt-12 max-w-prose">
      <CTAGuia />
    </div>
    */}

    <div class="mx-auto mt-10 max-w-prose border-t border-paper-300 pt-6">
      <a href="/blog" class="text-sm font-semibold text-clay-700 hover:text-clay-800">
        ← Volver al blog
      </a>
    </div>
  </article>

  <RelatedArticles post={post} />

  <!-- Espaciador para que la barra sticky móvil no tape el contenido/pie -->
  <div class="h-24 lg:hidden" aria-hidden="true"></div>

  <AsesoramientoCard />
</Base>
