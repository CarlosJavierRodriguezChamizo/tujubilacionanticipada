---
import Base from '../layouts/Base.astro';
import { breadcrumbSchema, webPageSchema } from '../lib/schema';

const path = '/asesoramiento';
const descripcion =
  'Asesoramiento personalizado sobre tu jubilación anticipada en España. Cuéntanos tu caso y te ayudamos a entender tus opciones, requisitos y penalizaciones.';

const beneficios = [
  'Analizamos tu caso concreto: edad, años cotizados y base reguladora.',
  'Te explicamos tus opciones de jubilación anticipada y su coste real.',
  'Resolvemos tus dudas sobre requisitos, plazos y trámites.',
  'Trato cercano y confidencial, sin compromiso.',
];

const schema = [
  webPageSchema({
    type: 'ContactPage',
    path,
    name: 'Asesoramiento personalizado sobre jubilación anticipada',
    description: descripcion,
    breadcrumbPath: path,
  }),
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Asesoramiento', path },
  ]),
];
---

<Base
  title="Asesoramiento personalizado sobre jubilación anticipada"
  description={descripcion}
  path={path}
  schema={schema}
>
  <!-- Hero -->
  <section class="border-b border-paper-200 bg-gradient-to-b from-clay-50/60 to-paper-50">
    <div class="container-prose py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">Asesoramiento</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight sm:text-5xl">
          ¿Tienes dudas sobre tu jubilación anticipada?
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">
          Cada situación es distinta. Cuéntanos la tuya y te ayudamos a entender
          tus opciones con claridad, sin tecnicismos y sin compromiso.
        </p>
      </div>
    </div>
  </section>

  <section class="container-prose py-14">
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Beneficios -->
      <div>
        <h2 class="text-2xl font-semibold">Qué incluye</h2>
        <ul class="mt-6 space-y-4">
          {
            beneficios.map((b) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-clay-100 text-clay-700"
                  aria-hidden="true"
                >
                  ✓
                </span>
                <span class="text-ink-soft">{b}</span>
              </li>
            ))
          }
        </ul>
        <p class="mt-8 rounded-lg border border-paper-300 bg-paper-100 p-4 text-sm text-ink-soft">
          Este servicio es orientativo y no sustituye la información oficial de la
          Seguridad Social ni el asesoramiento jurídico individualizado.
        </p>
      </div>

      <!-- Formulario -->
      <div>
        <div
          id="form-wrap"
          class="rounded-2xl border border-paper-300 bg-paper-50 p-6 shadow-sm sm:p-8"
        >
          <h2 class="text-xl font-semibold">Solicita tu asesoramiento</h2>
          <p class="mt-1 text-sm text-ink-muted">
            Rellena el formulario y te contactamos lo antes posible.
          </p>

          <form id="contact-form" class="mt-6 space-y-4" novalidate>
            <div>
              <label for="nombre" class="block text-sm font-medium text-ink">Nombre</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                autocomplete="name"
                class="mt-1.5 w-full rounded-lg border border-paper-300 bg-white px-3 py-2.5 text-base focus:border-clay-500 focus:outline-none focus:ring-2 focus:ring-clay-500"
              />
            </div>

            <div>
              <label for="telefono" class="block text-sm font-medium text-ink">Teléfono</label>
              <input
                id="telefono"
                name="telefono"
                type="tel"
                required
                autocomplete="tel"
                inputmode="tel"
                class="mt-1.5 w-full rounded-lg border border-paper-300 bg-white px-3 py-2.5 text-base focus:border-clay-500 focus:outline-none focus:ring-2 focus:ring-clay-500"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-ink">Correo electrónico</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                inputmode="email"
                class="mt-1.5 w-full rounded-lg border border-paper-300 bg-white px-3 py-2.5 text-base focus:border-clay-500 focus:outline-none focus:ring-2 focus:ring-clay-500"
              />
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-medium text-ink">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                required
                class="mt-1.5 w-full rounded-lg border border-paper-300 bg-white px-3 py-2.5 text-base focus:border-clay-500 focus:outline-none focus:ring-2 focus:ring-clay-500"
              ></textarea>
            </div>

            <!-- Honeypot anti-spam (oculto para personas) -->
            <div class="absolute left-[-9999px]" aria-hidden="true">
              <label>No rellenar<input name="empresa" type="text" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="flex items-start gap-2.5">
              <input
                id="consent"
                name="consent"
                type="checkbox"
                required
                class="mt-1 h-4 w-4 rounded border-paper-300 text-clay-600 focus:ring-clay-500"
              />
              <label for="consent" class="text-sm text-ink-soft">
                He leído y acepto la
                <a href="/privacidad" class="font-medium text-brand-700 underline hover:text-clay-700">
                  política de privacidad</a
                > y el tratamiento de mis datos para responder a mi consulta.
              </label>
            </div>

            <button type="submit" id="contact-submit" class="btn-accent w-full">
              Enviar solicitud
            </button>

            <p id="contact-error" class="hidden text-sm text-red-600" role="alert"></p>
          </form>
        </div>

        <!-- Mensaje de agradecimiento (oculto hasta el envío) -->
        <div
          id="form-thanks"
          class="hidden rounded-2xl border border-green-200 bg-green-50 p-8 text-center"
        >
          <div class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-green-100 text-2xl text-green-700" aria-hidden="true">
            ✓
          </div>
          <h2 class="mt-4 text-xl font-semibold text-green-900">¡Gracias por tu mensaje!</h2>
          <p class="mt-2 text-green-800">
            Hemos recibido tu solicitud y <strong>te avisaremos lo antes posible</strong>
            para resolver tu duda.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      if (!form) return;
      var errEl = document.getElementById('contact-error');
      var btn = document.getElementById('contact-submit');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        errEl.classList.add('hidden');

        if (!form.consent.checked) {
          errEl.textContent = 'Debes aceptar la política de privacidad para continuar.';
          errEl.classList.remove('hidden');
          return;
        }

        var payload = {
          nombre: form.nombre.value,
          telefono: form.telefono.value,
          email: form.email.value,
          mensaje: form.mensaje.value,
          consent: form.consent.checked,
          empresa: form.empresa.value,
        };

        btn.disabled = true;
        var prev = btn.textContent;
        btn.textContent = 'Enviando…';

        try {
          var resp = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          var data = await resp.json().catch(function () {
            return {};
          });

          if (resp.ok && data.ok) {
            document.getElementById('form-wrap').classList.add('hidden');
            document.getElementById('form-thanks').classList.remove('hidden');
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'generate_lead', { form: 'asesoramiento' });
            }
          } else {
            errEl.textContent =
              (data && data.error) || 'No se pudo enviar. Inténtalo de nuevo en un momento.';
            errEl.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = prev;
          }
        } catch (err) {
          errEl.textContent = 'No se pudo enviar. Revisa tu conexión e inténtalo de nuevo.';
          errEl.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = prev;
        }
      });
    })();
  </script>
</Base>
