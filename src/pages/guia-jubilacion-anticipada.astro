---
import Base from '../layouts/Base.astro';
import { SITE, GUIA_PRECIO } from '../consts';
import {
  productSchema,
  faqSchema,
  breadcrumbSchema,
  webPageSchema,
} from '../lib/schema';

const beneficios = [
  'Entiende exactamente a qué edad puedes jubilarte según tus años cotizados.',
  'Calcula el coste real de adelantar tu jubilación, trimestre a trimestre.',
  'Conoce los requisitos de la anticipada voluntaria y la forzosa.',
  'Aprende a leer tu informe de vida laboral y tu base reguladora.',
  'Evita los errores más caros al solicitar la pensión.',
  'Plantilla y checklist para preparar tu solicitud paso a paso.',
];

const indice = [
  'Cómo funciona el sistema de pensiones en España',
  'Edad legal de jubilación: tablas actualizadas',
  'Jubilación anticipada voluntaria: requisitos y penalizaciones',
  'Jubilación anticipada forzosa: cuándo y cómo se accede',
  'Cómo se calcula tu base reguladora y tu pensión',
  'Estrategias para reducir el impacto de las penalizaciones',
  'Documentación y trámite de la solicitud',
  'Preguntas frecuentes y errores habituales',
];

const faqs = [
  {
    q: '¿Está actualizada a la normativa vigente?',
    a: 'Sí. La guía recoge los parámetros vigentes del sistema de pensiones, con las tablas de edad y cotización aplicables.',
  },
  {
    q: '¿En qué formato la recibo?',
    a: 'Es un documento PDF descargable que puedes leer en cualquier dispositivo y consultar siempre que lo necesites.',
  },
  {
    q: '¿Sirve si soy autónomo?',
    a: 'La guía cubre el Régimen General y las particularidades más habituales del RETA, con avisos cuando hay diferencias relevantes.',
  },
];

// Sin pasarela de pago todavía: usamos un mailto como CTA de compra.
const mailtoCompra = `mailto:${SITE.email}?subject=${encodeURIComponent(
  'Quiero la guía de jubilación anticipada'
)}&body=${encodeURIComponent(
  'Hola, me interesa comprar la guía de jubilación anticipada (' +
    GUIA_PRECIO +
    '€). ¿Cómo continúo?'
)}`;

const path = '/guia-jubilacion-anticipada';
const descripcion =
  'Guía práctica en PDF para planificar tu jubilación anticipada en España: requisitos, penalizaciones, cálculo de la pensión y trámite de la solicitud.';

const schema = [
  productSchema({
    name: 'Guía de jubilación anticipada',
    description: descripcion,
    price: GUIA_PRECIO,
    path,
  }),
  faqSchema(faqs),
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Guía de jubilación anticipada', path },
  ]),
  webPageSchema({
    path,
    name: 'Guía de jubilación anticipada (PDF)',
    description: descripcion,
    breadcrumbPath: path,
  }),
];
---

<Base
  title="Guía de jubilación anticipada (PDF)"
  description={`Guía práctica en PDF (${GUIA_PRECIO}€) para planificar tu jubilación anticipada en España: requisitos, penalizaciones, cálculo de la pensión y cómo solicitarla.`}
  path={path}
  schema={schema}
>
  <!-- Hero de producto -->
  <section class="border-b border-gray-200 bg-gradient-to-b from-brand-50/60 to-white">
    <div class="container-prose grid gap-10 py-16 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">
          Guía en PDF · Descarga inmediata
        </p>
        <h1 class="mt-3 text-4xl font-bold leading-tight sm:text-5xl">
          Planifica tu jubilación anticipada sin perderte en la burocracia
        </h1>
        <p class="mt-5 text-lg text-ink-soft">
          Una guía clara y práctica que te lleva de la mano desde "no entiendo
          nada" hasta "sé exactamente cuándo y cómo jubilarme".
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={mailtoCompra} class="btn-primary no-underline">
            Comprar la guía · {GUIA_PRECIO}€
          </a>
          <span class="text-sm text-ink-muted">Pago único · Sin suscripción</span>
        </div>
        <p class="mt-3 text-sm text-ink-muted">
          ✓ Garantía de devolución de 14 días
        </p>
      </div>

      <!-- Mockup del producto -->
      <div class="flex justify-center">
        <div class="w-full max-w-xs rounded-2xl border border-gray-200 bg-white p-8 shadow-lg">
          <div class="aspect-[3/4] rounded-lg bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white">
            <p class="text-xs uppercase tracking-widest text-brand-100">Guía</p>
            <p class="mt-2 text-2xl font-bold leading-tight">
              Jubilación Anticipada
            </p>
            <p class="mt-1 text-sm text-brand-100">
              Requisitos, penalizaciones y cómo solicitarla
            </p>
            <div class="mt-8 space-y-2">
              <div class="h-1.5 w-3/4 rounded bg-white/30"></div>
              <div class="h-1.5 w-2/3 rounded bg-white/30"></div>
              <div class="h-1.5 w-5/6 rounded bg-white/30"></div>
            </div>
          </div>
          <p class="mt-4 text-center text-sm font-medium text-ink">
            Formato PDF · Actualizada
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="container-prose py-16">
    <h2 class="text-2xl font-bold sm:text-3xl">Qué vas a conseguir</h2>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        beneficios.map((b) => (
          <li class="flex items-start gap-3 rounded-xl border border-gray-200 bg-white p-5">
            <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700" aria-hidden="true">
              ✓
            </span>
            <span class="text-ink-soft">{b}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Índice de contenidos -->
  <section class="bg-gray-50">
    <div class="container-prose py-16">
      <h2 class="text-2xl font-bold sm:text-3xl">Qué incluye la guía</h2>
      <p class="mt-2 max-w-2xl text-ink-soft">
        {indice.length} capítulos que cubren todo el proceso, del principio al
        final.
      </p>
      <ol class="mt-8 grid gap-3 sm:grid-cols-2">
        {
          indice.map((cap, i) => (
            <li class="flex items-start gap-3 rounded-lg bg-white p-4">
              <span class="text-sm font-bold text-brand-600">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-sm text-ink">{cap}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Garantía -->
  <section class="container-prose py-16">
    <div class="rounded-2xl border border-green-200 bg-green-50 p-8 text-center sm:p-10">
      <h2 class="text-2xl font-bold text-green-900">Garantía de 14 días</h2>
      <p class="mx-auto mt-3 max-w-2xl text-green-800">
        Si después de leer la guía no te resulta útil, escríbenos en un plazo de
        14 días y te devolvemos el importe íntegro. Sin preguntas y sin
        complicaciones.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-prose pb-16">
    <h2 class="text-2xl font-bold sm:text-3xl">Preguntas frecuentes</h2>
    <div class="mt-8 space-y-3">
      {
        faqs.map((f) => (
          <details class="group rounded-xl border border-gray-200 bg-white p-5">
            <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-ink [&::-webkit-details-marker]:hidden">
              {f.q}
              <span class="text-ink-muted transition-transform group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-brand-600">
    <div class="container-prose py-14 text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">
        Empieza a planificar hoy
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-100">
        Toma el control de tu jubilación con una guía clara, práctica y al grano.
      </p>
      <a
        href={mailtoCompra}
        class="btn mt-6 bg-white text-brand-700 no-underline hover:bg-brand-50"
      >
        Comprar la guía · {GUIA_PRECIO}€
      </a>
      <p class="mt-3 text-sm text-brand-100">Garantía de 14 días</p>
    </div>
  </section>
</Base>
