---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
// Guía oculta temporalmente: import CTAGuia from '../components/CTAGuia.astro';
import { SITE } from '../consts';
import { getPublishedPosts } from '../lib/posts';
import { webPageSchema } from '../lib/schema';

const posts = (await getPublishedPosts()).slice(0, 3);

const homeSchema = webPageSchema({
  path: '/',
  name: SITE.name,
  description: SITE.description,
});

const pasos = [
  {
    n: '01',
    titulo: 'Conoce tu edad legal',
    texto:
      'Depende de tus años cotizados: 65 años con 38,5 cotizados, o 66 años y 8 meses con menos.',
  },
  {
    n: '02',
    titulo: 'Calcula la penalización',
    texto:
      'Adelantar la jubilación reduce tu pensión: 1,875 % por trimestre en la voluntaria, 1,625 % en la forzosa.',
  },
  {
    n: '03',
    titulo: 'Decide con datos',
    texto:
      'Compara escenarios, pesa el coste de adelantar y elige el momento que encaje con tu vida.',
  },
];
---

<Base
  title={SITE.name}
  description={SITE.description}
  path="/"
  schema={homeSchema}
>
  <!-- Hero -->
  <section class="grain border-b border-paper-200 bg-paper-100">
    <div class="container-prose py-16 sm:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow">Jubilación anticipada en España</p>
        <h1 class="mt-4 font-serif text-4xl font-semibold leading-[1.08] tracking-tight text-ink sm:text-6xl">
          Entiende tu pensión.
          <span class="text-clay-700">Decide cuándo jubilarte.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
          Información clara y sin tecnicismos para entender cuánto cobrarás y
          cuándo puedes jubilarte. Calcula tu pensión estimada en un minuto y
          decide con todos los datos sobre la mesa.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/simulador" class="btn-accent no-underline">
            Calcular mi jubilación
          </a>
          <a href="/blog" class="btn-secondary no-underline">
            Leer el blog
          </a>
        </div>
        <p class="mt-5 text-xs text-ink-muted">
          Gratis · Orientativo · Sin registro para usar el simulador
        </p>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="container-prose py-16 sm:py-20">
    <p class="eyebrow">Cómo funciona</p>
    <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Cómo planificar tu jubilación</h2>
    <p class="mt-3 max-w-2xl text-lg text-ink-soft">
      Tres pasos para pasar de la incertidumbre a una decisión informada.
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        pasos.map((p) => (
          <div class="rounded-xl border border-paper-200 bg-paper-50 p-6 shadow-card">
            <span class="font-serif text-3xl font-semibold text-clay-600">{p.n}</span>
            <h3 class="mt-3 text-lg font-semibold">{p.titulo}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{p.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Banner simulador -->
  <section class="container-prose">
    <div class="grain flex flex-col items-start gap-5 overflow-hidden rounded-2xl bg-brand-700 p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10">
      <div>
        <h2 class="text-2xl font-semibold text-white sm:text-3xl">
          ¿Cuánto cobrarías si te jubilas antes?
        </h2>
        <p class="mt-2 max-w-xl text-brand-100">
          Introduce tu edad, años cotizados y base reguladora. Te mostramos la
          pensión estimada en cada escenario.
        </p>
      </div>
      <a href="/simulador" class="btn-accent shrink-0 no-underline">
        Abrir el simulador
      </a>
    </div>
  </section>

  <!-- Últimos artículos -->
  {
    posts.length > 0 && (
      <section class="container-prose py-16 sm:py-20">
        <div class="flex items-end justify-between">
          <div>
            <p class="eyebrow">Blog</p>
            <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Últimos artículos</h2>
          </div>
          <a href="/blog" class="shrink-0 text-sm font-semibold text-clay-700 hover:text-clay-800">
            Ver todos →
          </a>
        </div>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  {/* CTA guía oculta temporalmente hasta que el producto esté definido.
  <CTAGuia variant="banner" />
  */}
</Base>
