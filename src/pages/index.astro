---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CTAGuia from '../components/CTAGuia.astro';
import { SITE } from '../consts';
import { getPublishedPosts } from '../lib/posts';
import { webPageSchema } from '../lib/schema';

const posts = (await getPublishedPosts()).slice(0, 3);

const homeSchema = webPageSchema({
  path: '/',
  name: SITE.name,
  description: SITE.description,
});

const pasos = [
  {
    n: '01',
    titulo: 'Conoce tu edad legal',
    texto:
      'Depende de tus años cotizados: 65 años con 38,5 cotizados, o 66 años y 8 meses con menos.',
  },
  {
    n: '02',
    titulo: 'Calcula la penalización',
    texto:
      'Adelantar la jubilación reduce tu pensión: 1,875 % por trimestre en la voluntaria, 1,625 % en la forzosa.',
  },
  {
    n: '03',
    titulo: 'Decide con datos',
    texto:
      'Compara escenarios, pesa el coste de adelantar y elige el momento que encaje con tu vida.',
  },
];
---

<Base
  title={SITE.name}
  description={SITE.description}
  path="/"
  schema={homeSchema}
>
  <!-- Hero -->
  <section class="border-b border-gray-200 bg-gradient-to-b from-brand-50/60 to-white">
    <div class="container-prose py-16 sm:py-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">
          Jubilación anticipada en España
        </p>
        <h1 class="mt-3 text-4xl font-bold leading-[1.1] sm:text-5xl">
          {SITE.tagline}
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">
          Información clara y sin tecnicismos para entender cuánto cobrarás y
          cuándo puedes jubilarte. Calcula tu pensión estimada en un minuto y
          decide con todos los datos sobre la mesa.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/simulador" class="btn-primary no-underline">
            Calcular mi jubilación
          </a>
          <a href="/blog" class="btn-secondary no-underline">
            Leer el blog
          </a>
        </div>
        <p class="mt-4 text-xs text-ink-muted">
          Gratis · Orientativo · Sin registro para usar el simulador
        </p>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="container-prose py-16">
    <h2 class="text-2xl font-bold sm:text-3xl">Cómo planificar tu jubilación</h2>
    <p class="mt-2 max-w-2xl text-ink-soft">
      Tres pasos para pasar de la incertidumbre a una decisión informada.
    </p>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {
        pasos.map((p) => (
          <div class="rounded-xl border border-gray-200 bg-white p-6">
            <span class="text-sm font-bold text-brand-600">{p.n}</span>
            <h3 class="mt-2 text-lg font-semibold">{p.titulo}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{p.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Banner simulador -->
  <section class="container-prose">
    <div class="flex flex-col items-start gap-4 rounded-2xl border border-gray-200 bg-gray-50 p-8 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-xl font-bold sm:text-2xl">
          ¿Cuánto cobrarías si te jubilas antes?
        </h2>
        <p class="mt-1 max-w-xl text-ink-soft">
          Introduce tu edad, años cotizados y base reguladora. Te mostramos la
          pensión estimada en cada escenario.
        </p>
      </div>
      <a href="/simulador" class="btn-primary shrink-0 no-underline">
        Abrir el simulador
      </a>
    </div>
  </section>

  <!-- Últimos artículos -->
  {
    posts.length > 0 && (
      <section class="container-prose py-16">
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold sm:text-3xl">Últimos artículos</h2>
          <a href="/blog" class="text-sm font-medium text-brand-600 hover:text-brand-700">
            Ver todos →
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  <!-- CTA guía -->
  <CTAGuia variant="banner" />
</Base>
