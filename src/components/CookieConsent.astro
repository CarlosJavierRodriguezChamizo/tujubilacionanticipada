---
/**
 * Banner de consentimiento de cookies (CMP).
 *
 * Implementa Google Consent Mode v2 con categorías granulares, bloqueo previo
 * (ningún tag no esencial se activa sin consentimiento), rechazo tan fácil como
 * la aceptación y revocación en cualquier momento. Cumple con RGPD/LSSI y la
 * Guía de cookies de la AEPD.
 *
 * El estado por defecto (todo denegado) se fija en `BaseHead.astro`, antes de
 * cargar cualquier tag. Este componente solo gestiona la interfaz y actualiza
 * el consentimiento cuando el usuario elige.
 */
import { COOKIE_CONSENT } from '../consts';

const { cookieName, version, maxAgeDays } = COOKIE_CONSENT;

const CATEGORIES = [
  {
    key: 'analytics',
    title: 'Analíticas',
    desc: 'Nos ayudan a entender de forma anónima cómo se usa el sitio (páginas más visitadas, errores) para mejorarlo.',
  },
  {
    key: 'marketing',
    title: 'Publicidad',
    desc: 'Permiten medir campañas y mostrar anuncios más relevantes. Incluyen identificadores publicitarios de Google.',
  },
  {
    key: 'preferences',
    title: 'Preferencias',
    desc: 'Recuerdan tus ajustes (por ejemplo, opciones ya vistas) para personalizar tu experiencia.',
  },
] as const;
---

<!-- Botón flotante para reabrir la configuración (revocación en cualquier momento) -->
<button
  id="cc-reopen"
  type="button"
  data-cc-open
  class="fixed bottom-4 left-4 z-40 hidden h-11 w-11 items-center justify-center rounded-full border border-paper-300 bg-paper-50 text-ink-soft shadow-card transition-colors hover:bg-paper-100"
  aria-label="Configurar cookies"
  title="Configurar cookies"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <circle cx="12" cy="12" r="9" />
    <circle cx="9" cy="9" r="1" fill="currentColor" stroke="none" />
    <circle cx="15" cy="10" r="1" fill="currentColor" stroke="none" />
    <circle cx="10" cy="14.5" r="1" fill="currentColor" stroke="none" />
    <circle cx="14.5" cy="14.5" r="1" fill="currentColor" stroke="none" />
  </svg>
</button>

<!-- Primera capa: banner -->
<div
  id="cc-banner"
  class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-paper-200 bg-paper-50 shadow-[0_-4px_24px_rgba(38,50,78,0.12)]"
  role="dialog"
  aria-modal="false"
  aria-live="polite"
  aria-label="Aviso de cookies"
>
  <div class="container-prose flex flex-col gap-4 py-5 lg:flex-row lg:items-center lg:gap-8">
    <div class="text-sm leading-relaxed text-ink-soft">
      <p class="mb-1 font-serif text-lg font-semibold text-ink">Valoramos tu privacidad</p>
      <p>
        Usamos cookies propias y de terceros para el funcionamiento del sitio y,
        con tu permiso, para analítica y publicidad. Puedes aceptarlas todas,
        rechazarlas o elegir por categorías. Más información en la
        <a href="/cookies" class="underline hover:text-brand-700">política de cookies</a>
        y la
        <a href="/privacidad" class="underline hover:text-brand-700">política de privacidad</a>.
      </p>
    </div>
    <div class="flex shrink-0 flex-col gap-2 sm:flex-row lg:justify-end">
      <button id="cc-reject" type="button" class="btn-secondary px-4 py-2.5 text-sm">
        Rechazar todo
      </button>
      <button id="cc-settings" type="button" data-cc-open class="btn-secondary px-4 py-2.5 text-sm">
        Configurar
      </button>
      <button id="cc-accept" type="button" class="btn-primary px-4 py-2.5 text-sm">
        Aceptar todo
      </button>
    </div>
  </div>
</div>

<!-- Segunda capa: panel de preferencias -->
<div
  id="cc-modal"
  class="fixed inset-0 z-[60] hidden items-end justify-center bg-black/50 p-0 sm:items-center sm:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cc-modal-title"
>
  <div class="flex max-h-[90vh] w-full max-w-lg flex-col overflow-hidden rounded-t-2xl bg-paper-50 shadow-xl sm:rounded-2xl">
    <div class="flex items-center justify-between border-b border-paper-200 px-6 py-4">
      <h2 id="cc-modal-title" class="font-serif text-lg font-semibold text-ink">Configuración de cookies</h2>
      <button id="cc-close" type="button" class="rounded-md p-1 text-ink-muted hover:bg-paper-100 hover:text-ink" aria-label="Cerrar">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <div class="overflow-y-auto px-6 py-5">
      <p class="mb-5 text-sm leading-relaxed text-ink-soft">
        Elige qué categorías quieres permitir. Las cookies necesarias no se
        pueden desactivar porque el sitio no funcionaría sin ellas. Puedes
        cambiar tu decisión cuando quieras desde el botón de cookies.
      </p>

      <!-- Necesarias (siempre activas) -->
      <div class="mb-3 flex items-start justify-between gap-4 rounded-xl border border-paper-200 bg-paper-100 p-4">
        <div>
          <p class="text-sm font-semibold text-ink">Necesarias</p>
          <p class="mt-1 text-sm leading-relaxed text-ink-soft">
            Imprescindibles para la seguridad y el funcionamiento básico. No
            requieren consentimiento.
          </p>
        </div>
        <span class="mt-0.5 shrink-0 rounded-full bg-clay-100 px-3 py-1 text-xs font-semibold text-clay-800">
          Siempre activas
        </span>
      </div>

      {
        CATEGORIES.map((cat) => (
          <div class="mb-3 flex items-start justify-between gap-4 rounded-xl border border-paper-200 p-4">
            <div>
              <p class="text-sm font-semibold text-ink">{cat.title}</p>
              <p class="mt-1 text-sm leading-relaxed text-ink-soft">{cat.desc}</p>
            </div>
            <label class="relative mt-0.5 inline-flex shrink-0 cursor-pointer items-center">
              <input type="checkbox" data-cc-category={cat.key} class="peer sr-only" />
              <span class="h-6 w-11 rounded-full bg-gray-300 transition-colors peer-checked:bg-brand-600 peer-focus-visible:ring-2 peer-focus-visible:ring-brand-500 peer-focus-visible:ring-offset-2" />
              <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform peer-checked:translate-x-5" />
              <span class="sr-only">Activar {cat.title}</span>
            </label>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col gap-2 border-t border-paper-200 px-6 py-4 sm:flex-row sm:justify-between">
      <button id="cc-modal-reject" type="button" class="btn-secondary px-4 py-2.5 text-sm">
        Rechazar todo
      </button>
      <div class="flex flex-col gap-2 sm:flex-row">
        <button id="cc-save" type="button" class="btn-secondary px-4 py-2.5 text-sm">
          Guardar preferencias
        </button>
        <button id="cc-modal-accept" type="button" class="btn-primary px-4 py-2.5 text-sm">
          Aceptar todo
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ cookieName, version, maxAgeDays }}>
  (function () {
    var CATS = ['analytics', 'marketing', 'preferences'];

    var banner = document.getElementById('cc-banner');
    var modal = document.getElementById('cc-modal');
    var reopen = document.getElementById('cc-reopen');
    if (!banner || !modal) return;

    function gtagUpdate(cats) {
      if (typeof window.gtag !== 'function') return;
      window.gtag('consent', 'update', {
        ad_storage: cats.marketing ? 'granted' : 'denied',
        ad_user_data: cats.marketing ? 'granted' : 'denied',
        ad_personalization: cats.marketing ? 'granted' : 'denied',
        analytics_storage: cats.analytics ? 'granted' : 'denied',
        functionality_storage: cats.preferences ? 'granted' : 'denied',
        personalization_storage: cats.preferences ? 'granted' : 'denied',
      });
      window.dataLayer.push({ event: 'cookie_consent_update', consent: cats });
    }

    function readConsent() {
      try {
        var m = document.cookie.match(
          new RegExp('(?:^|;\\s*)' + cookieName + '=([^;]+)')
        );
        if (!m) return null;
        var data = JSON.parse(decodeURIComponent(m[1]));
        if (data && data.v === version && data.categories) return data.categories;
      } catch (e) {}
      return null;
    }

    function saveConsent(cats) {
      var payload = { v: version, ts: new Date().toISOString(), categories: cats };
      var maxAge = maxAgeDays * 24 * 60 * 60;
      document.cookie =
        cookieName +
        '=' +
        encodeURIComponent(JSON.stringify(payload)) +
        ';path=/;max-age=' +
        maxAge +
        ';SameSite=Lax';
      gtagUpdate(cats);
    }

    function setToggles(cats) {
      CATS.forEach(function (k) {
        var input = modal.querySelector('[data-cc-category="' + k + '"]');
        if (input) input.checked = !!(cats && cats[k]);
      });
    }

    function readToggles() {
      var cats = {};
      CATS.forEach(function (k) {
        var input = modal.querySelector('[data-cc-category="' + k + '"]');
        cats[k] = !!(input && input.checked);
      });
      return cats;
    }

    var allOn = { analytics: true, marketing: true, preferences: true };
    var allOff = { analytics: false, marketing: false, preferences: false };

    var lastFocus = null;

    function showBanner() {
      banner.classList.remove('hidden');
    }
    function hideBanner() {
      banner.classList.add('hidden');
    }
    function showReopen() {
      if (reopen) reopen.classList.replace('hidden', 'flex');
    }
    function openModal() {
      setToggles(readConsent() || allOff);
      lastFocus = document.activeElement;
      modal.classList.replace('hidden', 'flex');
      document.body.style.overflow = 'hidden';
      var first = document.getElementById('cc-close');
      if (first) first.focus();
      document.addEventListener('keydown', onKeydown);
    }
    function closeModal() {
      modal.classList.replace('flex', 'hidden');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKeydown);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }
    function onKeydown(e) {
      if (e.key === 'Escape') closeModal();
    }

    function finish(cats) {
      saveConsent(cats);
      hideBanner();
      closeModal();
      showReopen();
    }

    // Botones — primera capa
    on('cc-accept', function () {
      finish(allOn);
    });
    on('cc-reject', function () {
      finish(allOff);
    });
    // Botones — panel de preferencias
    on('cc-modal-accept', function () {
      finish(allOn);
    });
    on('cc-modal-reject', function () {
      finish(allOff);
    });
    on('cc-save', function () {
      finish(readToggles());
    });
    on('cc-close', closeModal);

    // Abrir panel desde cualquier disparador (banner, footer, botón flotante)
    document.querySelectorAll('[data-cc-open]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        openModal();
      });
    });

    // Cerrar al pulsar el fondo oscuro
    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    function on(id, fn) {
      var el = document.getElementById(id);
      if (el) el.addEventListener('click', fn);
    }

    // Estado inicial: si ya hay consentimiento válido, solo el botón flotante;
    // si no, mostramos el banner.
    if (readConsent()) {
      showReopen();
    } else {
      showBanner();
    }
  })();
</script>
