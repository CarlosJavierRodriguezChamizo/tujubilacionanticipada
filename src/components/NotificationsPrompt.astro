---
import { SITE, VAPID_PUBLIC_KEY } from '../consts';
---

{
  VAPID_PUBLIC_KEY && (
    <div
      id="push-prompt"
      class="fixed left-4 top-4 z-50 hidden w-[min(360px,calc(100vw-2rem))] rounded-xl border border-paper-300 bg-white p-4 shadow-xl"
      role="dialog"
      aria-live="polite"
      aria-label="Suscripción a notificaciones"
    >
      <div class="flex items-start gap-3">
        <img src="/logo.png" alt="" width="40" height="40" class="h-10 w-10 shrink-0 rounded-md" />
        <div class="min-w-0">
          <p class="text-sm font-semibold text-ink">Suscríbete para recibir notificaciones</p>
          <p class="mt-0.5 text-sm text-ink-soft">
            Te avisaremos con las últimas novedades y artículos de {SITE.name}.
          </p>
        </div>
      </div>
      <div class="mt-4 flex items-center justify-end gap-2">
        <button type="button" id="push-decline" class="rounded-md px-3 py-2 text-sm font-medium text-ink-soft hover:bg-paper-100">
          No, gracias
        </button>
        <button type="button" id="push-allow" class="btn-accent px-4 py-2 text-sm">
          Permitir
        </button>
      </div>
    </div>

    <script is:inline define:vars={{ vapid: VAPID_PUBLIC_KEY }}>
      (function () {
        if (
          !('serviceWorker' in navigator) ||
          !('PushManager' in window) ||
          !('Notification' in window)
        )
          return;

        var DISMISS_KEY = 'tja_push_dismissed';
        var prompt = document.getElementById('push-prompt');
        var allowBtn = document.getElementById('push-allow');
        var declineBtn = document.getElementById('push-decline');

        function urlB64ToUint8Array(base64String) {
          var padding = '='.repeat((4 - (base64String.length % 4)) % 4);
          var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
          var raw = atob(base64);
          var arr = new Uint8Array(raw.length);
          for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
          return arr;
        }

        function hide() {
          if (prompt) prompt.style.display = 'none';
        }

        function dismissedRecently() {
          try {
            var v = localStorage.getItem(DISMISS_KEY);
            return v && Date.now() < parseInt(v, 10);
          } catch (e) {
            return false;
          }
        }

        var swReg = null;
        navigator.serviceWorker
          .register('/sw.js')
          .then(function (reg) {
            swReg = reg;
            if (Notification.permission === 'default' && !dismissedRecently()) {
              setTimeout(function () {
                if (prompt) prompt.style.display = 'block';
              }, 6000);
            }
          })
          .catch(function () {});

        async function subscribe() {
          try {
            if (!swReg) swReg = await navigator.serviceWorker.ready;
            var perm = await Notification.requestPermission();
            if (perm !== 'granted') {
              hide();
              return;
            }
            var sub = await swReg.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: urlB64ToUint8Array(vapid),
            });
            await fetch('/api/push-subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subscription: sub }),
            });
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'push_subscribe');
            }
          } catch (e) {
            /* el usuario denegó o hubo un error: no bloqueamos nada */
          }
          hide();
        }

        if (allowBtn) allowBtn.addEventListener('click', subscribe);
        if (declineBtn)
          declineBtn.addEventListener('click', function () {
            hide();
            try {
              // No volver a preguntar en 30 días.
              localStorage.setItem(DISMISS_KEY, String(Date.now() + 30 * 864e5));
            } catch (e) {}
          });
      })();
    </script>
  )
}
