---
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  /** Ruta de la página (ej. "/blog"). Se usa para el canonical. */
  path?: string;
  /** Imagen OG absoluta o ruta en /public */
  image?: string;
  /** Tipo Open Graph */
  ogType?: 'website' | 'article';
  /** Evita indexación */
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  image = SITE.defaultOgImage,
  ogType = 'website',
  noindex = false,
} = Astro.props;

// Canonical robusto: usa Astro.url contra el site configurado.
const canonicalURL = new URL(path ?? Astro.url.pathname, Astro.site ?? SITE.url);
const ogImageURL = new URL(image, Astro.site ?? SITE.url);

// Título completo: evita duplicar la marca en la home.
const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
---

<!-- Generales -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- SEO primario -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
{
  image === SITE.defaultOgImage && (
    <>
      <meta property="og:image:width" content={String(SITE.ogImageWidth)} />
      <meta property="og:image:height" content={String(SITE.ogImageHeight)} />
      <meta property="og:image:type" content="image/png" />
    </>
  )
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Tipografía -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
/>
